# ===========================================
# PEYAA BACKEND ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in values

# --- General ---
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8081

# --- Admin Seed ---
ADMIN_EMAIL=admin@peyaa.com
ADMIN_PASSWORD=

# --- Database ---
MONGO_URI=mongodb://localhost:27017/peyaa

# --- JWT ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Peyaa <contact@peyaa.com>

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- VTPass ---
VTPASS_BASE_URL=https://sandbox.vtpass.com/api
VTPASS_API_KEY=
VTPASS_PUBLIC_KEY=
VTPASS_SECRET_KEY=

# --- Paystack ---
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=

# --- Apple OAuth ---
APPLE_CLIENT_ID=

# --- OTP ---
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# --- Rate Limiting ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
