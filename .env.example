# ===========================================
# PEYAA BACKEND ENVIRONMENT VARIABLES — TEMPLATE
# ===========================================
# Copy this file to .env and fill in real values.
# DO NOT commit real secrets to this file.

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ===========================================
# DEFAULT ADMIN ACCOUNT (seeded on first startup)
# ===========================================
ADMIN_EMAIL=admin@peyaa.com
ADMIN_PASSWORD=change-me-on-first-login

# ===========================================
# DATABASE (MongoDB)
# ===========================================
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/peyaa?retryWrites=true&w=majority

# ===========================================
# JWT AUTHENTICATION
# Generate via: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ===========================================
JWT_ACCESS_SECRET=replace-with-32-plus-char-random-string
JWT_REFRESH_SECRET=replace-with-different-32-plus-char-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ===========================================
# EMAIL (SMTP - Nodemailer)
# ===========================================
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@your-domain.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Peyaa <contact@your-domain.com>"

# ===========================================
# CLOUDINARY (Image Uploads)
# ===========================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===========================================
# VTPASS (VTU Provider - Airtime, Data, Electricity, TV)
# Get keys from https://www.vtpass.com (sandbox) or live
# Sandbox uses Basic Auth (username/password); live uses API keys
# ===========================================
VTPASS_BASE_URL=https://sandbox.vtpass.com/api
VTPASS_API_KEY=your-vtpass-api-key
VTPASS_SECRET_KEY=your-vtpass-secret-key
VTPASS_PUBLIC_KEY=your-vtpass-public-key
VTPASS_USERNAME=your-vtpass-account-email
VTPASS_PASSWORD=your-vtpass-account-password

# ===========================================
# PAYSTACK (Wallet Top-up)
# ===========================================
PAYSTACK_SECRET_KEY=sk_test_or_live_your_key_here
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# ===========================================
# GOOGLE SIGN-IN
# Get from Google Cloud Console -> APIs & Services -> Credentials
# ===========================================
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ===========================================
# APPLE SIGN-IN
# Get from Apple Developer Portal -> Certificates, Identifiers & Profiles
# ===========================================
APPLE_CLIENT_ID=com.yourapp.bundleid
# Optional: If using private key validation instead of JWKS
# APPLE_TEAM_ID=your-team-id
# APPLE_KEY_ID=your-key-id
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Key-Here\n-----END PRIVATE KEY-----"

# ===========================================
# OTP CONFIGURATION
# ===========================================
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# ===========================================
# QUIDAX (Crypto Buy/Sell)
# Get from https://www.quidax.com/developers
# ===========================================
QUIDAX_API_SECRET_KEY=your-quidax-api-secret
QUIDAX_BASE_URL=https://app.quidax.io/api/v1
QUIDAX_WEBHOOK_SECRET=your-quidax-webhook-secret

# ===========================================
# CLOUDFLARE R2 (Brand Logo Uploads)
# ===========================================
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# ===========================================
# RATE LIMITING (Optional)
# ===========================================
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# ===========================================
# MONO (KYC Identity Verification)
# ===========================================
MONO_SECRET_KEY=your-mono-secret-key
